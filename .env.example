# ============================================================
# Variables de entorno – copiar a .env y completar valores
# Paso 4 (Docker): secrets externos, nunca hardcodeados en imagen
# ============================================================

# LLM – Claude API (Paso 9: query rewriting + respuesta RAG)
ANTHROPIC_API_KEY=sk-ant-...

# Vector store en producción (Paso 8: sharded storage)
# Cambiar VECTOR_BACKEND=pinecone en prod
VECTOR_BACKEND=chromadb         # opciones: chromadb | pinecone | qdrant
PINECONE_API_KEY=               # solo si VECTOR_BACKEND=pinecone
PINECONE_ENVIRONMENT=           # ej. us-east-1-aws

# Observabilidad (Paso 11)
LOG_LEVEL=INFO
METRICS_PORT=9090

# Multi-región (Paso 10) – configurar según región de despliegue
AWS_REGION=us-east-1
REPLICA_REGIONS=us-west-2,eu-west-1
